*{
margin: 0;
padding: 0;
}

body {
height: 100%;
font-size: 100%;
font-family: san-serif;
background: black;
overflow: visible;
	
}

a, p a {
text-decoration: none;
}

p {
font-size: 0.9em;
line-height: 1.5em;
margin-bottom: 0.8em;
}

li {
list-style: none;
font-size: 1em;
line-height: 1.3em;
margin-bottom: 0.5em;
}

h1 {
font-size: 1.5em; 
margin-bottom: 0.8em;
}

h2 {
font-size: 1.1em;
margin-bottom: 0.5em;
}

h3 {
font-size: 1.002em;
margin-bottom: 0.5em;
}

.clear {clear: both;}

div#pagewrap {
min-height:100%;
width: 1024px;
position: relative;
margin: 0 auto;
background: #6c5367;
background: linear-gradient(top, #6c5367, #2f435c);
	background: -moz-linear-gradient(top, #6c5367, #2f435c);
	background: -webkit-linear-gradient(top, #6c5367, #2f435c); 
border-left: 3px solid white;
border-right: 3px solid white;
border-bottom: 3px solid white;
-webkit-border-bottom-right-radius: 20px;
-webkit-border-bottom-left-radius: 20px;
-moz-border-radius-bottomright: 20px;
-moz-border-radius-bottomleft: 20px;
border-bottom-right-radius: 20px;
border-bottom-left-radius: 20px;

}

div#header {
display: block;
position: relative;
height: 200px;
background: url("header.png") top center no-repeat;
}

.credit{margin-top: 2px; text-align: center; font-size: 0.7em; color: white; font-family: sans-serif;}
.credit a{color: #ffcc00; }

div#maincontent {
width:  1020px;
display: block;
position: relative;
margin: 20px auto 20px auto;
padding: 0 30px 0 30px;
font-family: sans-serif;
color: white;
text-align: center;
 }

div#maincontent a{
color: #f48135;
}

div#maincontent a:hover, 
div#maincontent a:active {color: #f48135;}

div#maincontent img{
width: 200px;
height: 200px;
border: 8px solid white;
-webkit-border-radius: 30px;
-moz-border-radius: 30px;
border-radius: 30px;
}
div#maincontent img:hover{
box-shadow: 3px 3px 0px #b3b3b3;}

ul#properties {
width: 1020px;
height:260px;
margin: 40px 0 0 20px;
}

ul#properties li a{
float: left;
display: inline-block;
padding: 0 40px 0 40px;
font-size: 1.2em;
font-weight: bold;
color: white;
} 

ul#properties li a:hover{
color: white;
text-shadow: 1px 1px 2px #b3b3b3;}


