*{
margin: 0;
padding: 0;
}

body {
height: 100%;
font-size: 100%;
font-family: san-serif;
background: black;
overflow: visible;
}

a, p a {
text-decoration: none;
}

p {
font-size: 0.9em;
line-height: 1.5em;
margin-bottom: 0.8em;
}

li {
list-style: none;
font-size: 1em;
line-height: 1.3em;
margin-bottom: 0.5em;
}

h1 {
font-size: 1.5em; 
margin-bottom: 0.8em;
}

h2 {
font-size: 1.1em;
margin-bottom: 0.5em;
}

h3 {
font-size: 1.002em;
margin-bottom: 0.5em;
}

.clear {clear: both;}

div#pagewrap {
min-height:100%;
width: 1024px;
position: relative;
margin: 0 auto;
background: #aad400;
border-left: 5px solid #ffeeaa;
border-right: 5px solid #ffeeaa;
border-bottom: 5px solid #ffeeaa;
padding: 3px;
}

div#header {
display: block;
position: relative;
height: 180px;
background: url(images/header.png) top center no-repeat;
}

div#navigation {
position: relative;
width: 950px;
margin: 0px auto 0px auto;
}

div#navigation li{
display: inline-block;
margin-top: 135px;
padding: 5px 38px 5px 38px;
font-family: 'Bubbler One', sans-serif;
font-size: 2.3em;
font-weight: 400;
color: black;
}

div#navigation li a{
color: white;
}

div#navigation li a:hover, div#nav li a:active  {
color: black;
}

div#footer {
display: block;
position: relative;
height: 83px;
background: url(images/footer.png) top center no-repeat;
padding-top: 20px;
margin-top: 20px;
text-align: center;
font-family: 'Bubbler One', sans-serif;
font-size: 1.1em;
font-weight: bold;
color: #ffeeaa;
}

div#footer a{
color: #ffcc00;
}

.credit{margin-top: 2px; text-align: center; font-size: 0.7em; color: white; font-family: sans-serif;}
.credit a{color: #ffcc00; }

div#maincontent {
min-height: 275px;
padding: 30px;
font-family: sans-serif;
color: black;
 }

div#maincontent p {
margin-left: 20px;
}
div#maincontent li{
margin-left: 40px;
font-size: 0.9em;
}

div#maincontent a{
color: #ffdd55;
}

div#maincontent a:hover, 
div#maincontent a:active {color: #ffdd55;}

div#maincontent a img:hover{border: 1px solid #ffcc00;}

div#textmain{
display: block;
position: relative;
margin-bottom: 20px;	
width: 280px;
}

div#amenities{
display: block;
position: relative;
width: 300px;
margin-left: 50px;}

/*image gallery code*/

.wrapper {
	width: 650px;
	position: relative;
	display: block;
	margin: 0 auto;
}
.wrapper .thumbnails {
	width: 150px;
	float: right;
}
.wrapper a {
	margin: 2px;
}
.wrapper img {
	border: 1px solid white;
}
.wrapper label > img {
	opacity: 0.6;
}
.wrapper label > img:hover {
	opacity: 1;
}
.wrapper input {
	display: none;
}
.wrapper input:checked + .full-image {
	display: block;
}
.wrapper input:checked ~ img {
	opacity: 1;
}
.wrapper .full-image {
	display: none;
	position: absolute;
	top: 0;
	left: 0;
}
